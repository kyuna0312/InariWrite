{
  "name": "@inariwrite/web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:embedded": "tsc -b && cross-env VITE_EMBEDDED=1 vite build",
    "mobile:sync": "pnpm run build:embedded && cap sync",
    "mobile:add:android": "cap add android",
    "mobile:add:ios": "cap add ios",
    "mobile:open:android": "cap open android",
    "mobile:open:ios": "cap open ios",
    "lint": "eslint src",
    "typecheck": "tsc -b --noEmit",
    "test:e2e": "playwright test",
    "budget": "node scripts/check-dist-budget.mjs"
  },
  "dependencies": {
    "@codemirror/commands": "^6.7.1",
    "@codemirror/lang-markdown": "^6.3.2",
    "@codemirror/state": "^6.5.0",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.35.0",
    "@inariwrite/core": "workspace:*",
    "@inariwrite/i18n": "workspace:*",
    "@inariwrite/plugin-sample": "workspace:*",
    "i18next": "^24.2.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^15.2.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@playwright/test": "^1.49.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^10.1.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-window": "^7.3.0"
  }
}
