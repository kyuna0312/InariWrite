{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "InariWrite",
  "version": "0.0.1",
  "identifier": "dev.inariwrite.desktop",
  "build": {
    "beforeDevCommand": "pnpm -C ../.. --filter @inariwrite/web dev --host 127.0.0.1 --port 5173",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "pnpm -C ../.. --filter @inariwrite/web run build:embedded",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "InariWrite",
        "width": 1100,
        "height": 780,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
